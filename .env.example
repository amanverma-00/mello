# Server
PORT=3001
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://melo:melo_dev@localhost:5432/melo

# Redis
REDIS_URL=redis://localhost:6379

# Spotify (get from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# JWT (file paths for local dev, inline keys for containers)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# JWT_PRIVATE_KEY=  # Optional: inline PEM content (for Fly.io / Render / Docker)
# JWT_PUBLIC_KEY=   # Optional: inline PEM content (for Fly.io / Render / Docker)

# App
APP_URL=http://localhost:5173
SESSION_MAX_PARTICIPANTS=50
SESSION_TTL_HOURS=6
