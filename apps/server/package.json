{
  "name": "@melo/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/migrate.ts",
    "generate-keys": "tsx src/scripts/generate-keys.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@melo/shared": "workspace:*",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.0",
    "jose": "^6.0.0",
    "kysely": "^0.27.0",
    "nanoid": "^5.0.0",
    "pg": "^8.13.0",
    "pino": "^9.6.0",
    "socket.io": "^4.8.0",
    "spotify-web-api-node": "^5.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/spotify-web-api-node": "^5.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "ioredis-mock": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
